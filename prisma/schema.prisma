generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Transaction {
  id                Int      @id @default(autoincrement())
  date              DateTime
  description       String
  amount            Decimal
  cardName          String?
  installmentNumber Int?
  totalInstallments Int?
  importId          String
  createdAt         DateTime @default(now())
}
